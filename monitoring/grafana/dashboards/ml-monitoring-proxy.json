      "id": 8,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_proxy_run AS (SELECT id, COALESCE(segment_key, '__global__') AS segment_key, ts_started, status FROM quality_runs WHERE model_version = '${model_version}' AND status IN ('completed_proxy', 'completed') ORDER BY ts_started DESC, id DESC LIMIT 1) SELECT latest_proxy_run.segment_key, latest_proxy_run.status, quality_metrics.metric_name, quality_metrics.metric_value, quality_metrics.baseline_value, quality_metrics.delta_value, quality_metrics.severity, quality_metrics.recommended_action FROM latest_proxy_run JOIN quality_metrics ON quality_metrics.run_id = latest_proxy_run.id WHERE quality_metrics.detector_name = 'proxy' ORDER BY CASE quality_metrics.severity WHEN 'critical' THEN 3 WHEN 'warning' THEN 2 ELSE 1 END DESC, ABS(COALESCE(quality_metrics.delta_value, 0)) DESC, quality_metrics.metric_name ASC",
          "refId": "A"
        }
      ],
      "title": "Latest Proxy Quality Metrics",
      "type": "table"
    }
