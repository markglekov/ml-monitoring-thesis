      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_drift AS (SELECT COALESCE(segment_key, '__global__') AS segment_key, status AS drift_status, drifted_features_count, total_features_count, overall_drift, COALESCE(summary_json ->> 'severity', CASE WHEN overall_drift THEN 'warning' ELSE 'none' END) AS drift_severity, ROW_NUMBER() OVER (PARTITION BY COALESCE(segment_key, '__global__') ORDER BY ts_started DESC, id DESC) AS rn FROM monitoring_runs WHERE model_version = '${model_version}'), latest_quality AS (SELECT COALESCE(segment_key, '__global__') AS segment_key, status AS quality_status, labeled_rows, degraded_metrics_count, COALESCE(summary_json ->> 'severity', CASE WHEN degraded_metrics_count > 0 THEN 'warning' ELSE 'none' END) AS quality_severity, ROW_NUMBER() OVER (PARTITION BY COALESCE(segment_key, '__global__') ORDER BY ts_started DESC, id DESC) AS rn FROM quality_runs WHERE model_version = '${model_version}'), segments AS (SELECT DISTINCT COALESCE(segment_key, '__global__') AS segment_key FROM monitoring_runs WHERE model_version = '${model_version}' UNION SELECT DISTINCT COALESCE(segment_key, '__global__') AS segment_key FROM quality_runs WHERE model_version = '${model_version}' UNION SELECT DISTINCT COALESCE(segment_key, '__global__') AS segment_key FROM monitoring_incidents WHERE model_version = '${model_version}') SELECT segments.segment_key, latest_drift.drift_status, latest_drift.drift_severity, latest_drift.drifted_features_count, latest_quality.quality_status, latest_quality.quality_severity, latest_quality.degraded_metrics_count, latest_quality.labeled_rows FROM segments LEFT JOIN latest_drift ON latest_drift.segment_key = segments.segment_key AND latest_drift.rn = 1 LEFT JOIN latest_quality ON latest_quality.segment_key = segments.segment_key AND latest_quality.rn = 1 ORDER BY segments.segment_key ASC",
          "refId": "A"
        }
      ],
      "title": "Latest Segment Monitoring Snapshot",
      "type": "table"
    },
