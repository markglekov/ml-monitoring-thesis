        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(segment_key, '__global__') AS segment_key, source_type, severity, status, title, recommended_action, acknowledged_by, mitigation_taken, ts_opened, ts_updated, ts_resolved FROM monitoring_incidents WHERE model_version = '${model_version}' ORDER BY CASE severity WHEN 'critical' THEN 3 WHEN 'warning' THEN 2 ELSE 1 END DESC, ts_updated DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Incident Timeline",
      "type": "table"
