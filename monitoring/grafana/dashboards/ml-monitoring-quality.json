      "id": 9,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_completed_run AS (SELECT id, COALESCE(segment_key, '__global__') AS segment_key, ts_started FROM quality_runs WHERE model_version = '${model_version}' AND status = 'completed' ORDER BY ts_started DESC, id DESC LIMIT 1) SELECT latest_completed_run.segment_key, quality_metrics.metric_name, quality_metrics.metric_value, quality_metrics.baseline_value, quality_metrics.delta_value, quality_metrics.severity, quality_metrics.recommended_action FROM latest_completed_run JOIN quality_metrics ON quality_metrics.run_id = latest_completed_run.id WHERE quality_metrics.detector_name = 'labeled' ORDER BY CASE quality_metrics.severity WHEN 'critical' THEN 3 WHEN 'warning' THEN 2 ELSE 1 END DESC, ABS(COALESCE(quality_metrics.delta_value, 0)) DESC, quality_metrics.metric_name ASC",
          "refId": "A"
        }
      ],
      "title": "Latest Labeled Quality Metrics",
      "type": "table"
    }
