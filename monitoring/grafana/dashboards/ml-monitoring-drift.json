    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH ranked_runs AS (SELECT id, ts_started, COALESCE(segment_key, '__global__') AS segment_key, status, drifted_features_count, total_features_count, overall_drift, COALESCE(summary_json ->> 'severity', CASE WHEN overall_drift THEN 'warning' ELSE 'none' END) AS severity, summary_json ->> 'recommended_action' AS recommended_action, ROW_NUMBER() OVER (PARTITION BY COALESCE(segment_key, '__global__') ORDER BY ts_started DESC, id DESC) AS rn FROM monitoring_runs WHERE model_version = '${model_version}') SELECT segment_key, ts_started, status, severity, overall_drift, drifted_features_count, total_features_count, recommended_action FROM ranked_runs WHERE rn = 1 ORDER BY CASE severity WHEN 'critical' THEN 3 WHEN 'warning' THEN 2 ELSE 1 END DESC, drifted_features_count DESC, segment_key ASC",
          "refId": "A"
        }
      ],
      "title": "Latest Drift Runs By Segment",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 6,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_run AS (SELECT id, COALESCE(segment_key, '__global__') AS segment_key, ts_started FROM monitoring_runs WHERE model_version = '${model_version}' ORDER BY ts_started DESC, id DESC LIMIT 1) SELECT COALESCE(drift_metrics.segment_key, latest_run.segment_key) AS segment_key, drift_metrics.feature_name, drift_metrics.feature_type, drift_metrics.detector_name, drift_metrics.statistic, drift_metrics.pvalue, drift_metrics.effect_size, drift_metrics.pvalue_adj, drift_metrics.psi_value, drift_metrics.window_start, drift_metrics.window_end, drift_metrics.severity, drift_metrics.drift_detected, drift_metrics.recommended_action FROM latest_run JOIN drift_metrics ON drift_metrics.run_id = latest_run.id ORDER BY CASE drift_metrics.severity WHEN 'critical' THEN 3 WHEN 'warning' THEN 2 ELSE 1 END DESC, drift_metrics.effect_size DESC NULLS LAST, drift_metrics.feature_name ASC LIMIT 30",
          "refId": "A"
        }
      ],
      "title": "Latest Drift Feature Details",
      "type": "table"
    }
