LOG_LEVEL=INFO

POSTGRES_DB=ml_monitoring
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops
POSTGRES_HOST=localhost
POSTGRES_PORT=55432

MODEL_PATH=artifacts/models/bank_marketing_model.joblib
BASELINE_PATH=artifacts/baselines/baseline_profile.json
MODEL_VERSION=bank_marketing_v1
MONITORING_SEGMENTS=
SCHEDULER_INCLUDE_GLOBAL_SEGMENT=true
REACTION_ENGINE_ENABLED=true
REACTION_ENGINE_MODE=dry_run
REACTION_THRESHOLD_STEP=0.05
REACTION_THRESHOLD_CAP=0.95
REACTION_MANUAL_REVIEW_PROBABILITY=1.0

API_HOST=0.0.0.0
API_PORT=8000

PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

SCHEDULER_DRIFT_INTERVAL_SEC=300
SCHEDULER_QUALITY_INTERVAL_SEC=300
SCHEDULER_DRIFT_WINDOW_SIZE=300
SCHEDULER_QUALITY_WINDOW_SIZE=300
SCHEDULER_DRIFT_MIN_ROWS=50
SCHEDULER_QUALITY_MIN_ROWS=50
SCHEDULER_QUALITY_BASELINE_SOURCE=test

# Gmail example: use an App Password, not your regular account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SEC=15

# Optional local SMTP sink for testing:
# docker compose --profile mailpit up -d mailpit email-relay
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
